{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/refund", "dest": "/refund.html" },
    { "src": "/terms", "dest": "/terms.html" }
  ]
}